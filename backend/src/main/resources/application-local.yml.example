# 복사해서 application-local.yml 로 사용 (gitignore 대상)
# 시크릿은 환경변수 주입 — yml에 실제 값 커밋 금지 (SpringBoot_코드_컨벤션.md §9)
# 시크릿 값은 루트 .env 에 작성(DB_PASSWORD, REDIS_PASSWORD 등) — 단 Spring Boot가 .env 를 자동 로드하지 않으므로
#   IntelliJ: EnvFile 플러그인으로 Run Configuration 에 .env 연결
#   터미널: export $(grep -v '^#' .env | xargs) && ./gradlew bootRun
# 접속 전 SSH 터널 필요: ssh -N hajacheck-db (설정은 ~/.ssh/config 의 Host hajacheck-db 참조)
# → 로컬 localhost:5432(PostgreSQL) / localhost:6380(Redis) 가 공용 개발 서버로 포워딩됨
# (SSH 터널 없이 로컬 자체 컨테이너로 개발한다면: 루트 docker-compose.yml 로 `docker compose up -d postgres redis`
#  실행 — 기본 DB명이 hajacheck_dev 라 아래 url 은 그 값을 그대로 쓴다. docs/conventions/로컬_개발_가이드.md 참고)
#
# ⚠️ 공유 DB 오염 주의: local 프로파일은 known-password ADMIN 시드(dev@hajacheck.local / dev1234)를 생성할 수 있다.
#    기본값은 false(옵트인) — 아래 app.local-seed.enabled 를 본인이 직접 true 로 켜야만 시드가 생성된다.
#    본인 로컬 격리 DB(compose)에서만 true 로 켜고, SSH 터널로 "공용 개발 서버"에 붙은 상태면 절대 켜지 말 것
#    (known 계정이 공유 DB에 그대로 생성됨).
spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/hajacheck_dev
    username: hajacheck
    password: ${DB_PASSWORD}
  data:
    redis:
      host: localhost
      port: 6380
      password: ${REDIS_PASSWORD}
      database: 1   # 개발은 1번 (운영 0번)
  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
  security:
    oauth2:
      client:
        registration:
          kakao:
            client-id: ${KAKAO_CLIENT_ID}
            client-secret: ${KAKAO_CLIENT_SECRET}
            client-authentication-method: client_secret_post
            authorization-grant-type: authorization_code
            # 인가 base-uri 를 /api/auth/oauth2 로 커스텀했으므로 redirect-uri 경로는 /login/oauth2/code/* 유지
            redirect-uri: "{baseUrl}/login/oauth2/code/{registrationId}"
            # account_email 미요청 — 개인 카카오 앱은 이메일 동의항목 활성화 불가 → 요청 시 KOE205(#202). 이메일은 placeholder 처리(#199).
            scope:
              - profile_nickname
            client-name: Kakao
          google:
            client-id: ${GOOGLE_CLIENT_ID}
            client-secret: ${GOOGLE_CLIENT_SECRET}
            scope:
              - email
              - profile
        # 카카오는 표준 OIDC provider 가 아니라서 provider 블록을 직접 정의해야 한다.
        provider:
          kakao:
            authorization-uri: https://kauth.kakao.com/oauth/authorize
            token-uri: https://kauth.kakao.com/oauth/token
            user-info-uri: https://kapi.kakao.com/v2/user/me
            user-name-attribute: id

# 소셜 로그인 성공/실패 후 프론트 리다이렉트 대상(로컬 Vite dev 기준, prod 는 env override)
app:
  # 로컬 시드 유저(dev@hajacheck.local / dev1234, ADMIN) 생성 스위치.
  # 기본 false(옵트인) — 본인 로컬 격리 DB(compose)에서만 명시적으로 true 로 켜라.
  # SSH 터널로 공용 DB에 붙은 상태면 절대 true 로 켜지 말 것(공유 DB 오염 방지).
  local-seed:
    enabled: false
  oauth2:
    success-redirect: http://localhost:5173/dashboard
    failure-redirect: http://localhost:5173/login?error=oauth

ai:
  server:
    base-url: http://localhost:8000
    # 로컬 더미값 — 실제 시크릿 금지(FastAPI 는 아직 검증 안 하지만 프록시가 미리 부착한다, #228)
    internal-key: local-dev-internal-key
