# 복사해서 .env.local 로 사용 (gitignore 대상)
# VITE_* 만 사용, 시크릿은 프론트에 두지 않음 (빌드 산출물에 노출됨)
VITE_APP_TITLE=hajaCheck
# MSW 목서버 on/off — 기본(미설정/true)은 켜짐(MSW로 화면 개발).
# 실 로컬 백엔드 연동 테스트 시 false 로 두면 모든 요청이 Vite proxy를 통해 실 백엔드로 나간다.
VITE_ENABLE_MSW=true
# Kakao JavaScript 키 — Kakao Developers 콘솔에서 발급 (지도 뷰, #28)
# 클라이언트 번들에 노출되는 공개 키이므로 Kakao Developers 콘솔 > 플랫폼 > Web 에서 허용 도메인을 반드시 등록할 것 (미등록 시 타 도메인에서 키 도용 가능)
VITE_KAKAO_MAP_APP_KEY=your-kakao-map-app-key-here
