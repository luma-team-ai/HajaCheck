# 복사해서 .env 로 사용 (gitignore 대상)

DB_URL=jdbc:postgresql://localhost:5432/hajacheck_dev
DB_USER=hajacheck
DB_PASSWORD=your-db-password-here
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-here

# OAuth
KAKAO_CLIENT_ID=your-kakao-client-id-here
KAKAO_CLIENT_SECRET=your-kakao-client-secret-here
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Claude API KEY /OCR 전용
CLAUDE_API_KEY=your-claude-api-key-here

# 스프링↔FastAPI 공유 내부키 — 스프링이 /api/ai/* 프록시에 X-Internal-Key로 부착, FastAPI가 검증(#235)
# 운영(arm1)은 필수(미설정 시 기동 실패). 빈값이면 FastAPI 검증 비활성(로컬/dev, nginx 폐쇄가 1차 방어)
AI_INTERNAL_KEY=

# --- Docker Compose 전용 (docker-compose.yml — 로컬/운영 컨테이너 스택) ---
# postgres/redis 컨테이너 자격증명은 위 DB_USER/DB_PASSWORD/REDIS_PASSWORD를 그대로 재사용한다.
# (SSH 터널 시나리오와 별개 — compose 내부에서는 서비스명(postgres/redis)으로 직접 접속)
POSTGRES_DB=hajacheck_dev
# Redis DB 인덱스(운영 0번 / 개발 1번, PRD §6.1). base 격리 스택은 기본 0.
# ⚠️ arm1은 dev 스택이므로 서버 .env에서 REDIS_DB_INDEX=1 로 설정할 것
# (미설정 시 docker-compose.arm1.yml fallback 1이 적용되나, 아래처럼 명시값 0이 있으면 0이 우선되니 주의).
REDIS_DB_INDEX=0

# ai-server LLM 클라이언트(ai/core/llm_client.py) — 미설정 시 HF provider 호출 지점에서만 에러
LLM_PROVIDER=hf
LLM_MODEL=Qwen/Qwen3-8B
HF_API_TOKEN=your-hf-api-token-here
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:8b

# 운영 배포 전용(deploy/deploy.sh가 주입) — latest 금지, 버전+커밋 SHA
IMAGE_TAG=

# deploy/deploy.sh 실행 서버의 로컬 .env에 **필수**(vm 또는 arm1 — 미설정/오타 시 deploy.sh가
# 즉시 exit 1하도록 안전화되어 있음, 공유 호스트 오작동 방지). vm=전용 VM(base+prod 풀스택),
# arm1=공유 호스트(docker-compose.arm1.yml, bridge-net + 전용 postgres/redis 컨테이너, #258).
DEPLOY_TARGET=
# arm1 전용 postgres 컨테이너(127.0.0.1:5433)가 쓰는 DB명 — 컷오버(#258 런북) 전 공유 host
# postgres(5432)를 참조하던 시기의 DB명(hajacheck)과는 다르니 혼동 주의. arm1 외에는 미사용.
ARM1_DB_NAME=hajacheck_dev

# --- docker-compose.oci-db.yml (로컬 개발용 옵트인 오버레이) ---
# 로컬 Docker의 spring/fastapi를 db-tunnel(autossh) 컨테이너 경유로 OCI 공용 개발 DB에 붙인다.
# 본인 ~/.ssh/config 의 `Host hajacheck-db`(= oci-arm1) 항목과 동일한 값으로 채운다.
# 예: 158.179.169.146 또는 도메인
OCI_SSH_HOST=your-oci-host-here
# 예: opc
OCI_SSH_USER=your-oci-ssh-user-here
# 개인키 절대경로. 예: ~/.ssh/id_ed25519
OCI_SSH_KEY_PATH=/absolute/path/to/your/ssh/key
# OCI 상의 실제 PostgreSQL 포트
OCI_DB_REMOTE_PORT=5432
# OCI 상의 실제 Redis 포트(⚠️ 6379 아님 — sshd PermitOpen 엄격 검사)
OCI_REDIS_REMOTE_PORT=6380
