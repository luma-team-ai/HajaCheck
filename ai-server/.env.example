# 복사해서 .env 로 사용 (gitignore 대상)

REDIS_URL=redis://localhost:6379/0

# LLM Provider 선택 (기본값: "hf")
# LLM_PROVIDER=hf              # HuggingFace Serverless
# LLM_PROVIDER=ollama          # 로컬 Ollama 서버

# HuggingFace Serverless 설정 (LLM_PROVIDER=hf 일 때)
HF_API_TOKEN=your-token-here
# LLM_MODEL=Qwen/Qwen3-8B      # 기본값

# Ollama 설정 (LLM_PROVIDER=ollama 일 때, HF와 동일 모델)
# OLLAMA_MODEL=qwen3:8b
# OLLAMA_BASE_URL=http://localhost:11434

# LangSmith 트레이싱 (design-03-13) — get_llm()이 유일한 호출 지점이라 이 4줄만 켜면
# 모든 체인이 자동 트레이싱됨(코드 수정 불필요). 팀 공유 프로젝트 하나로 통일 — 누가 호출했는지는
# LangSmith UI에서 트레이스 메타데이터로 구분. 키 발급: https://smith.langchain.com
# LANGCHAIN_ENDPOINT는 계정 리전에 맞춰야 함(가입 시 자동 배정) — LangSmith UI 온보딩 화면의
# LANGSMITH_ENDPOINT 값 그대로 사용. 리전 안 맞추면 키가 멀쩡해도 403 Forbidden 남.
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_ENDPOINT=https://apac.api.smith.langchain.com
# LANGCHAIN_API_KEY=your-key-here
# LANGCHAIN_PROJECT=hajacheck
